# Runtime
NODE_ENV=production
PORT=3000

# Static build served by server/server.mjs.
# Leave empty/default if production serves the local Astro build output.
STATIC_DIR=./dist

# Security
# Generate a unique value with 32+ characters before deploying.
SESSION_SECRET=replace-with-a-long-random-secret-of-at-least-32-characters

# Persistent backend storage
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
DB_PATH=./data/db.json

# Upload limits
MAX_UPLOAD_MB=10
