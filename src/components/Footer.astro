---
import Icon from './Icon.astro';
import { getContent, social, type Lang } from '../i18n/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang);
const base = lang === 'es' ? '' : `/${lang}`;
const year = new Date().getFullYear();

const explore = [
  { href: `${base}/#nosotros`, label: t.nav.nosotros },
  { href: `${base}/#servicios`, label: t.nav.servicios },
  { href: `${base}/#sectores`, label: t.nav.sectores },
  { href: `${base}/#inversionistas`, label: t.nav.inversionistas },
  { href: `${base}/#acuerdos`, label: t.nav.acuerdos },
  { href: `${base}/#contacto`, label: t.nav.contacto },
];
const socials = [
  { href: social.instagram, icon: 'instagram', label: 'Instagram' },
  { href: social.facebook, icon: 'facebook', label: 'Facebook' },
  { href: social.linkedin, icon: 'linkedin', label: 'LinkedIn' },
  { href: social.whatsapp, icon: 'whatsapp', label: 'WhatsApp' },
];
---
<footer class="bg-ink-950 text-cream/90">
  <div class="container-x py-16">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-2.5">
          <img src="/images/logo-icon.png" alt="AVC Soluciones" class="h-10 w-10 rounded-lg object-contain" />
          <span class="font-display font-semibold text-lg">AVC <span class="text-gold-400">Soluciones</span></span>
        </div>
        <p class="mt-4 text-sm text-cream/60 leading-relaxed max-w-xs">{t.footer.tagline}</p>
        <div class="mt-5 flex gap-2">
          {socials.map((s) => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}
              class="grid place-items-center h-9 w-9 rounded-full border border-white/10 text-cream/70 hover:text-gold-400 hover:border-gold-400/50 transition">
              <Icon name={s.icon} class="w-4.5 h-4.5" />
            </a>
          ))}
        </div>
      </div>

      <!-- Explore -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-gold-400/90">{t.footer.explore}</h4>
        <ul class="mt-4 space-y-2.5">
          {explore.map((l) => (
            <li><a href={l.href} class="text-sm text-cream/70 hover:text-gold-400 transition">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-gold-400/90">{t.footer.contactTitle}</h4>
        <ul class="mt-4 space-y-3 text-sm text-cream/70">
          <li class="flex gap-2.5"><Icon name="phone" class="w-4.5 h-4.5 shrink-0 text-gold-400/80" /><a href={social.whatsapp} class="hover:text-gold-400 transition">{t.contact.whatsappValue}</a></li>
          <li class="flex gap-2.5"><Icon name="mail" class="w-4.5 h-4.5 shrink-0 text-gold-400/80" /><a href={`mailto:${t.contact.emailValue}`} class="hover:text-gold-400 transition">{t.contact.emailValue}</a></li>
          <li class="flex gap-2.5"><Icon name="pin" class="w-4.5 h-4.5 shrink-0 text-gold-400/80" /><a href={social.maps} target="_blank" rel="noopener" class="hover:text-gold-400 transition" data-google-maps-link data-contact-address>{t.contact.addressValue}</a></li>
          <li class="flex gap-2.5"><Icon name="clock" class="w-4.5 h-4.5 shrink-0 text-gold-400/80" /><span>{t.contact.hoursValue}</span></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-gold-400/90">Legal</h4>
        <ul class="mt-4 space-y-2.5">
          {t.footer.legal.map((l) => (
            <li><a href="#" class="text-sm text-cream/70 hover:text-gold-400 transition">{l}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-14 pt-6 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-cream/50">
      <p>© {year} AVC Soluciones Empresariales E.A.S. — {t.footer.rights}</p>
      <p>{t.footer.poweredBy}</p>
    </div>
  </div>
</footer>
