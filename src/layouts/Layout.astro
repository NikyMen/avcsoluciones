---
import '../styles/global.css';
import { social, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
  htmlLang: string;
  title: string;
  description: string;
}
const { htmlLang, title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/images/logo-icon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/logo.png" />
    <meta name="theme-color" content="#0b0b0f" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      />
    </noscript>
  </head>
  <body>
    <slot />
    <script is:inline>
      // Shield the "AVC" brand from browser auto-translation everywhere.
      // (In Portuguese, translators expand "AVC" into "accidente cerebrovascular".)
      (function protectBrand() {
        const BRAND = /AVC(?:\s+Soluciones(?:\s+Empresariales)?)?/g;
        const run = () => {
          const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, {
            acceptNode(node) {
              if (!node.nodeValue || !node.nodeValue.includes('AVC')) return NodeFilter.FILTER_REJECT;
              let el = node.parentElement;
              while (el) {
                const tag = el.tagName;
                if (tag === 'SCRIPT' || tag === 'STYLE') return NodeFilter.FILTER_REJECT;
                if (el.getAttribute('translate') === 'no') return NodeFilter.FILTER_REJECT;
                el = el.parentElement;
              }
              return NodeFilter.FILTER_ACCEPT;
            },
          });
          const targets = [];
          while (walker.nextNode()) targets.push(walker.currentNode);

          for (const node of targets) {
            const text = node.nodeValue;
            const frag = document.createDocumentFragment();
            let last = 0;
            let m;
            BRAND.lastIndex = 0;
            while ((m = BRAND.exec(text)) !== null) {
              if (m.index > last) frag.appendChild(document.createTextNode(text.slice(last, m.index)));
              const span = document.createElement('span');
              span.setAttribute('translate', 'no');
              span.textContent = m[0];
              frag.appendChild(span);
              last = m.index + m[0].length;
            }
            if (last < text.length) frag.appendChild(document.createTextNode(text.slice(last)));
            node.parentNode.replaceChild(frag, node);
          }
        };
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', run);
        } else {
          run();
        }
      })();
    </script>
    <a
      href={social.whatsapp}
      target="_blank"
      rel="noopener noreferrer"
      class="whatsapp-floating"
      aria-label="Contactar por WhatsApp"
    >
      <img src="/images/whatsapp-flotante.svg" alt="" aria-hidden="true" />
    </a>
    <script>
      const readContactLocation = async () => {
        try {
          const response = await fetch('/api/settings/location');
          if (!response.ok) return null;
          const { location } = await response.json();
          if (location?.address && location?.mapsUrl) return location;
        } catch {
          return null;
        }
        return null;
      };

      const applyContactLocation = async () => {
        const location = await readContactLocation();

        document.querySelectorAll('[data-google-maps-link]').forEach((link) => {
          if (!link.dataset.defaultMapsHref) link.dataset.defaultMapsHref = link.getAttribute('href') || '';
          link.setAttribute('href', location?.mapsUrl || link.dataset.defaultMapsHref);
          if (location?.address) {
            link.setAttribute('title', location.address);
          } else {
            link.removeAttribute('title');
          }
        });
        document.querySelectorAll('[data-contact-address]').forEach((node) => {
          if (!node.dataset.defaultAddressText) node.dataset.defaultAddressText = node.textContent || '';
          node.textContent = location?.address || node.dataset.defaultAddressText;
        });
      };

      applyContactLocation();

      // Reveal-on-scroll
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>

<style>
  .whatsapp-floating {
    position: fixed;
    right: clamp(1rem, 2vw, 1.75rem);
    bottom: clamp(1rem, 2vw, 1.75rem);
    z-index: 60;
    display: grid;
    width: 3.75rem;
    height: 3.75rem;
    place-items: center;
    border-radius: 999px;
    background: #25d366;
    box-shadow: 0 18px 38px -14px rgba(11, 11, 15, 0.55);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .whatsapp-floating:hover {
    transform: translateY(-3px);
    box-shadow: 0 22px 44px -14px rgba(11, 11, 15, 0.62);
  }

  .whatsapp-floating img {
    width: 100%;
    height: 100%;
    display: block;
  }

  @media (max-width: 640px) {
    .whatsapp-floating {
      width: 3.35rem;
      height: 3.35rem;
    }
  }
</style>
